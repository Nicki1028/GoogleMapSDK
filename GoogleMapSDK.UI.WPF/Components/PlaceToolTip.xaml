<UserControl x:Class="GoogleMapSDK.UI.WPF.Components.PlaceToolTip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="160" d:DesignWidth="280">
    <Border Background="White" 
            Padding="0" 
            CornerRadius="8" 
            BorderBrush="#E0E0E0" 
            BorderThickness="1">
        <StackPanel>
            <!-- 上方圖片 -->
            <Border Height="100" 
                    Background="#EEE" 
                    ClipToBounds="True"
                    CornerRadius="8,8,0,0">
                <Image Source="{Binding SourceURL}" 
                       Stretch="UniformToFill" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
            </Border>

            <!-- 下方資訊區 -->
            <StackPanel Margin="12,10,12,12">

                <!-- 第一行：標題 + 兩個圓形按鈕 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 標題 -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding Name}" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#202124"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- 右側兩個圓形按鈕 -->
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                Margin="8,0,0,0">
                        <Border Width="32" 
                                Height="32" 
                                Background="#E8F4F8" 
                                CornerRadius="16"
                                Margin="0,0,6,0">
                            <TextBlock Text="📍" 
                                       FontSize="16" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="32" 
                                Height="32" 
                                Background="#E8F4F8" 
                                CornerRadius="16">
                            <TextBlock Text="🔖" 
                                       FontSize="16" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 第二行：評分 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="4.4" 
                               FontSize="13" 
                               Foreground="#202124"
                               Margin="0,0,4,0"/>
                    <TextBlock Text="★★★★☆" 
                               FontSize="12" 
                               Foreground="#FBBC04"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="(2,097)" 
                               FontSize="13" 
                               Foreground="#70757A"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 第三行：類型 + 圖示 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="{Binding Description}" 
                               FontSize="13" 
                               Foreground="#70757A"
                               Margin="0,0,4,0"/>
                    <TextBlock Text="· 🚶" 
                               FontSize="13" 
                               Foreground="#70757A"/>
                </StackPanel>

                <!-- 第四行：營業狀態 -->
                <TextBlock FontSize="13" Margin="0,0,0,0">
                    <Run Text="已打烊" Foreground="#D93025" FontWeight="SemiBold"/>
                    <Run Text=" · 開始營業時間：週三10:00" Foreground="#70757A"/>
                </TextBlock>

            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>